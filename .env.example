# .env.example - BeerGaao 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# 注意：.env 文件已被 .gitignore 排除，请勿提交到版本控制系统

# ============================================================
# 可选配置 - Tushare（历史K线数据源）
# 如需使用 Tushare 数据源，请配置以下变量
# 安装依赖：pip install tushare 或 pip install -e ".[tushare]"
# ============================================================

# Tushare API Token（可选，仅 Tushare 数据源需要）
# 获取地址：https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# ============================================================
# 可选配置 - 长桥 OpenAPI（支持港股/美股）
# 如需使用港股/美股功能，请配置以下变量
# 建议使用只读权限的 API Token
# 安装依赖：pip install longport（或使用 pip install -e ".[dev]" 后单独安装）
# ============================================================

# 长桥 App Key
LONGPORT_APP_KEY=

# 长桥 App Secret
LONGPORT_APP_SECRET=

# 长桥 Access Token（建议只读权限）
LONGPORT_ACCESS_TOKEN=

# ============================================================
# 交易参数配置（可选）
# ============================================================

# 单个持仓最大比例（默认 0.30）
MAX_SINGLE_POSITION=0.30

# 总持仓最大比例（默认 0.80）
MAX_TOTAL_POSITION=0.80

# 最低市场评分（默认 4.0）
MIN_MARKET_SCORE=4.0

# 成交量倍数（默认 1.8）
VOL_MULTI=1.8

# 目标收益率（默认 0.06）
TARGET_RATE=0.06

# 止损率（默认 -0.04）
STOP_LOSS_RATE=-0.04

# 持仓天数（默认 5）
HOLD_DAYS=5

# 回测天数（默认 250）
BACKTEST_DAYS=250

# ============================================================
# 交易成本配置（可选）
# ============================================================

# 佣金费率（默认 0.0003）
COMMISSION_RATE=0.0003

# 印花税率（默认 0.001）
STAMP_TAX_RATE=0.001

# 滑点率（默认 0.001）
SLIPPAGE_RATE=0.001

# ============================================================
# 风险控制配置（可选）
# ============================================================

# 熔断跌幅（默认 -0.05）
CIRCUIT_BREAKER_DROP=-0.05

# 相关性阈值（默认 0.7）
CORRELATION_THRESHOLD=0.7

# ============================================================
# 系统配置（可选）
# ============================================================

# 轮询间隔秒数（默认 60）
POLL_INTERVAL=60

# HTTP 超时秒数（默认 10）
HTTP_TIMEOUT=10

# 最大重试次数（默认 3）
MAX_RETRIES=3

# 数据库路径（默认 stock_skill.db）
# 注意：数据库文件权限已设置为仅 owner 可读写（600）
DB_PATH=stock_skill.db

# 日志级别（默认 INFO）
LOG_LEVEL=INFO
